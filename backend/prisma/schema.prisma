  PICKUP_ONLY
  DELIVERY_ONLY
  BOTH_OPTIONS
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentPurpose {
  Top_List_Biz
  Top_List_Product
  Sponsored_Video
  Top_List_Notice
  Biz_Verification
  Sponsor
  Web_Banner
  Events
  In_app_notification
  Wallet_Funding
  Notice_Boost
}

enum TransactionType {
  FUNDING
  DEDUCTION
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum RequestStatus {
  PENDING
  CONTACTED
  RESOLVED
}

enum pricing_category {
  AD_CATEGORY
  TOP_LIST_CATEGORY
  OTHER_ADS
}

enum pricing_purpose {
  Top_List_Biz
  Top_List_Product
  Sponsored_Video
  Top_List_Notice
  Biz_Verification
  Sponsor
  Web_Banner
  Events
  In_app_notification
  Wallet_Funding
  Notice_Boost
}
