enum ContactType {
  INSTAGRAM
  FACEBOOK
  X
  TIKTOK
  WEBSITE
  WHATSAPP
  PHONE
  TELEGRAM
  EMAIL
}

enum TopListAd {
  BUSINESS_TOPLIST
  NOTICE_TOPLIST
  PRODUCT_TOPLIST
}

enum BusinessCategory {
  AGRIBUSINESS
  MANUFACTURING
  RETAIL_WHOLESALE
  TECHNOLOGY
  HEALTHCARE
  EDUCATION
  TOURISM_HOSPITALITY
  REAL_ESTATE
  TRANSPORT_LOGISTICS
